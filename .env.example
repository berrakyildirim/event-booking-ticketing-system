# Copy this file to .env and fill in the values before running the project.

# Development (SQLite — local only, never use in production)
DATABASE_URL="file:./dev.db"

# Production — replace with a managed cloud database URL (e.g. Supabase, Neon, AWS RDS)
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Long random string used to sign and verify JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
